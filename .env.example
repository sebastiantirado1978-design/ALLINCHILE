# ============================================================================
# ALLINCHILE — Variables de entorno
# Copia este archivo a `.env.local` y completa los valores reales.
# NUNCA commitees `.env.local`.
# ============================================================================

# ----------------------------------------------------------------------------
# Supabase (REQUERIDO para auth, DB y storage)
# Obtén estas claves en: https://app.supabase.com/project/_/settings/api
# ----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...        # SOLO server-side, nunca al cliente

# ----------------------------------------------------------------------------
# Anthropic Claude (REQUERIDO para copiloto IA en respuestas)
# Obtén tu API key en: https://console.anthropic.com/settings/keys
# ----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# ----------------------------------------------------------------------------
# App
# ----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=ALLINCHILE

# ----------------------------------------------------------------------------
# WhatsApp Business API (OPCIONAL - dejar vacío hasta tener cuenta Meta)
# https://developers.facebook.com/docs/whatsapp/cloud-api
# ----------------------------------------------------------------------------
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=

# ----------------------------------------------------------------------------
# Email transaccional (OPCIONAL - Resend recomendado)
# https://resend.com/api-keys
# ----------------------------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM=hola@allinchile.cl

# ----------------------------------------------------------------------------
# Integraciones e-commerce / CRM (OPCIONAL - se conectan por OAuth en UI)
# Aquí solo van las app credentials globales
# ----------------------------------------------------------------------------
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
